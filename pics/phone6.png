.control-namespace span,
.control-namespace iframe {
  font-size: 100%;
  font-style: normal;
}

.control-messenger-container {
  z-index: 2147483000;
  position: fixed;
  height: calc(100% - 120px);
  width: 360px;
  min-height: 250px;
  max-height: 704px;
  box-shadow: rgba(0, 0, 0, 0.16) 0px 5px 40px;

  opacity: 1;
  border-radius: 10px;
  overflow: hidden;
  transition: opacity 0.2s linear, bottom 0.2s linear !important;
}

:root {
  --resize-handle-width: 20px;
  --resize-handle-height: 20px;
}

.resize-handle {
  position: absolute;
  z-index: 10;
}

.resize-handle.topleft,
.resize-handle.topright,
.resize-handle.bottomleft,
.resize-handle.bottomright {
  width: var(--resize-handle-width);
  height: var(--resize-handle-height);
  transform: translate(50%, 50%);
}

.resize-handle.topleft {
  top: calc(0px - var(--resize-handle-height));
  left: calc(0px - var(--resize-handle-width));
  cursor: nwse-resize;
}

.resize-handle.topright {
  top: calc(0px - var(--resize-handle-height));
  right: calc(0px - var(--resize-handle-width));
  transform: translate(-50%, 50%);
  cursor: nesw-resize;
}

.resize-handle.bottomleft {
  bottom: calc(0px - var(--resize-handle-height));
  left: calc(0px - var(--resize-handle-width));
  transform: translate(50%, -50%);
  cursor: nesw-resize;
}

.resize-handle.bottomright {
  bottom: calc(0px - var(--resize-handle-height));
  right: calc(0px - var(--resize-handle-width));
  transform: translate(-50%, -50%);
  cursor: nwse-resize;
}

.resize-handle.top,
.resize-handle.bottom {
  width: 100%;
  height: var(--resize-handle-height);
}

.resize-handle.left,
.resize-handle.right {
  height: 100%;
  width: var(--resize-handle-width);
}

.resize-handle.top {
  top: calc(0px - var(--resize-handle-height));
  left: 0;
  transform: translate(0, 50%);
  cursor: ns-resize;
}

.resize-handle.bottom {
  bottom: calc(0px - var(--resize-handle-height));
  left: 0;
  transform: translate(0, -50%);
  cursor: ns-resize;
}

.resize-handle.left {
  top: 0;
  left: calc(0px - var(--resize-handle-width));
  transform: translate(50%, 0);
  cursor: ew-resize;
}

.resize-handle.right {
  top: 0;
  right: calc(0px - var(--resize-handle-width));
  transform: translate(-50%, 0);
  cursor: ew-resize;
}

.resize-handle.activeResizer {
  width: 100vw;
  height: 100vh;
  position: fixed;
  top: 0;
  left: 0;
  transform: translate(0, 0);
}

.control-form-container {
  width: 100%;
  height: 100%;

  iframe {
    width: 100%;
    height: 100%;
  }
}

.control-comments-container {
  min-height: 100px;
}

.control-messenger-container.control-hidden {
  bottom: -704px;
  opacity: 0;
}

.control-launcher-frame {
  z-index: 2147483001;
  border: 0;
  position: fixed;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  color-scheme: none;
  box-shadow: rgb(0 0 0 / 6%) 0px 1px 6px 0px, rgb(0 0 0 / 16%) 0px 2px 32px 0px;
  transition: opacity 0.2s linear 0s, bottom 0.2s linear 0s !important;
}

.control-launcher-frame.control-hidden {
  bottom: -60px;
  opacity: 0;
}

.control-messenger-frame {
  border: 0;
  width: 100%;
  height: 100%;
}

.control-comments-frame {
  border: 0;
  width: 100%;
  height: 100%;
  min-height: 500px;
}

.control-config-frame {
  position: absolute;
  left: -10000px;
  overflow: hidden;
  height: 0;
  width: 0;
}

@media (max-width: 900px) {
  .control-messenger-container:not(.control-hidden) {
    width: 100%;
    height: 100%;
    max-height: 100%;
    right: 0;
    left: 0 !important;
    top: 0 !important;
    bottom: 0;
    border-radius: 0;
  }

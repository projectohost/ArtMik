w - 320px)\u002F703)}}@media(min-width: 480px){#rkt-samsung-a36 .swiper-button-prev:hover{opacity:1}#rkt-samsung-a36 .swiper-button-prev.swiper-button-disabled{opacity:0}#rkt-samsung-a36 .rkt-samsung-a36-place__flex{display:-webkit-box;display:-webkit-flex;display:-moz-box;display:-ms-flexbox;display:flex;-webkit-box-pack:center;-webkit-justify-content:center;-moz-box-pack:center;-ms-flex-pack:center;justify-content:center}#rkt-samsung-a36 .rkt-samsung-a36-place__item:first-child{position:absolute;top:0;left:0}#rkt-samsung-a36 .rkt-samsung-a36-place__text{padding-top:10px}#rkt-samsung-a36 .rkt-samsung-a36-place__text h2,#rkt-samsung-a36 .rkt-samsung-a36-place__text p{text-align:left}#rkt-samsung-a36 .rkt-samsung-a36-selfie__flex{display:-webkit-box;display:-webkit-flex;display:-moz-box;display:-ms-flexbox;display:flex;-webkit-box-pack:center;-webkit-justify-content:center;-moz-box-pack:center;-ms-flex-pack:center;justify-content:center;-webkit-box-align:start;-webkit-align-items:flex-start;-moz-box-align:start;-ms-flex-align:start;align-items:flex-start;gap:20px}#rkt-samsung-a36 .rkt-samsung-a36-selfie__item{-webkit-box-flex:0;-webkit-flex:0 1 50%;-moz-box-flex:0;-ms-flex:0 1 50%;flex:0 1 50%}}@media(min-width: 768px){#rkt-samsung-a36 .rkt-samsung-a36-place__item:first-child{width:50%}#rkt-samsung-a36 .rkt-samsung-a36-place__item--right{right:0}#rkt-samsung-a36 .rkt-samsung-a36-place__item--right:first-child{left:auto}#rkt-samsung-a36 .rkt-samsung-a36-place__text h2,#rkt-samsung-a36 .rkt-samsung-a36-place__text p{text-align:left}#rkt-samsung-a36 .swiper-button-next{top:35%;right:30%}#rkt-samsung-a36 .swiper-button-next--position{right:1%}#rkt-samsung-a36 .swiper-button-prev{top:35%}#rkt-samsung-a36 .swiper-button-prev--position{top:50%}}\r\n\u003C\u002Fstyle\u003E\r\n\r\n    \u003Clink rel=\"stylesheet\" href=\"https:\u002F\u002Fcdn.jsdelivr.net\u002Fnpm\u002Fswiper@11\u002Fswiper-bundle.min.css\"\u003E\r\n\r\n    \u003Cscript src=\"https:\u002F\u002Fcdn.jsdelivr.net\u002Fnpm\u002Fswiper@11\u002Fswiper-bundle.min.js\"\u003E\u003C\u002Fscript\u003E\r\n\r\n\u003Cdiv id=\"rkt-samsung-a36\" class=\"rkt-global-style rkt-name-product__style\"\u003E\r\n          \u003Cdiv class=\"rkt-samsung-a36__container\"\u003E\r\n            \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F1.jpg\"\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-slider\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-slider__title\"\u003E\r\n                \u003Ch2\u003EПереглядайте головні моменти\u003C\u002Fh2\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"swiper mySwiper\"\u003E\r\n                \u003Cdiv class=\"swiper-wrapper\"\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F2.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__text\"\u003E\r\n                        \u003Ch2\u003EІнтелект, що захоплює\u003C\u002Fh2\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F3.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__text\"\u003E\r\n                        \u003Ch2\u003EСтворений, щоб виконувати різноманітні задачі\u003C\u002Fh2\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F4.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__text\"\u003E\r\n                        \u003Cp\u003EШестикратне оновлення операційної системи, для довготривалого користування\u003C\u002Fp\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F5.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__text\"\u003E\r\n                        \u003Cp\u003EKnox Vault – надійний захист вашої конфіденційної інформації\u003C\u002Fp\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-button-next\"\u003E\u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-button-prev\"\u003E\u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-pagination\"\u003E\u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-place\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-place__flex\"\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__text\"\u003E\r\n                    \u003Ch2\u003EЕлегантний та впізнаваний дизайн\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003E\r\n                      Мінімалізм та довговічна надійність поєднанні у Galaxy A36 5G, роблять його не тільки відмінним доповненням до вашого стилю, а й сучасним\r\n                      аксесуаром для повсякденного життя. Скляна задня поверхня та витончені рамки надають смартфону приголомшливого вигляду.\r\n                    \u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__image\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F6.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-slider\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-slider__title rkt-samsung-a36-slider__title--center\"\u003E\r\n                \u003Ch2\u003EОберіть найпривабливіший для себе колір.\u003C\u002Fh2\u003E\r\n                \u003Cp\u003EНіжний лавандовий, яскравий білий та глибокий чорний – ви обов’язково підберете ідеальний для себе колір.\u003C\u002Fp\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"swiper mySwiper2\"\u003E\r\n                \u003Cdiv class=\"swiper-wrapper\"\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F7.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F8.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F9.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-button-next swiper-button-next--position\"\u003E\u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-button-prev swiper-button-prev--position\"\u003E\u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-pagination swiper-pagination-color\"\u003E\u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-content\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-content__text\"\u003E\r\n                \u003Ch2\u003EВеликий дисплей для захопливого ігрового досвіду\u003C\u002Fh2\u003E\r\n                \u003Cp\u003E\r\n                  6,7-дюймовий FHD+ Super AMOLED дисплей з частотою оновлення 120 Гц та рівнем яскравості до 1200 ніт чудово підходить для динамічних ігор та\r\n                  подарує вам незабутній ігровий досвід.\r\n                \u003C\u002Fp\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-content__image\"\u003E\r\n                \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F10.jpg\"\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-place\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-place__flex\"\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item rkt-samsung-a36-place__item--right\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__text\"\u003E\r\n                    \u003Ch2\u003EСтворений, щоб виконувати різноманітні задачі\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003E\r\n                      Galaxy A36 5G є взірцем багатозадачності, його потужні центральний, мережевий та графічний процесори з легкістю впораються з іграми,\r\n                      онлайн-трансляціями чи улюбленими шоу. Також на цій моделі на 15% збільшено камеру для охолодження, що забезпечує дотримання оптимального\r\n                      температурного режиму.\r\n                    \u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__image\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F11.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-place\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-place__flex\"\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__text\"\u003E\r\n                    \u003Ch2\u003EБагатофункціональна автономність\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003E\r\n                      До 29 годин перегляду відео – тепер, це не фантазія, а реальність. Потужний акумулятор на 5000 мАг буде відмінним гарантом автономності, а\r\n                      технологія швидкої зарядки Super Fast Charge, що має потужність 45W, допоможе швидко поновити заряд.\r\n                    \u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__image\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F12.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-selfie\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-selfie__title\"\u003E\r\n                \u003Ch2\u003EСучасний рівень безпеки\u003C\u002Fh2\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-selfie__flex\"\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-selfie__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__img\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F13.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__text\"\u003E\r\n                    \u003Ch2\u003EСмартфон на довгі роки\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003E\r\n                      6 поколінь оновлень операційної системи та 6 років оновлення протоколів безпеки забезпечать Galaxy A36 5G довготривалу актуальність та\r\n                      ефективність роботи.\r\n                    \u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-selfie__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__img\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F14.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__text\"\u003E\r\n                    \u003Ch2\u003EНадійний захист з Knox Vault\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003E\r\n                      Samsung Knox Vault з рівнем сертифікації EAL5+ надійно захистить ваші персональні дані, подбайте про свою безпеку обравши Galaxy A36 5G.\r\n                    \u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-slider\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-slider__title\"\u003E\r\n                \u003Ch2\u003EІнтелект, що захоплює\u003C\u002Fh2\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"swiper mySwiper3\"\u003E\r\n                \u003Cdiv class=\"swiper-wrapper\"\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F15.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__text\"\u003E\r\n                        \u003Ch2\u003EДостатньо обвести\u003C\u002Fh2\u003E\r\n                        \u003Cp\u003E\r\n                          Один з найлегших способів пошуку буде доступний вам завдяки ШІ, швиденько обведіть те, що вас цікавить, а далі смартфон зробить все за\r\n                          вас.\r\n                        \u003C\u002Fp\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F16.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__text\"\u003E\r\n                        \u003Ch2\u003EІнтелектуальні фільтри в Galaxy A36 5G\u003C\u002Fh2\u003E\r\n                        \u003Cp\u003E\r\n                          Зробіть свої знімки унікальними за допомогою вбудованих фільтрів. Вони проводять аналіз ваших фото, щоб надати їм особливих ефектів.\r\n                        \u003C\u002Fp\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"swiper-slide\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-slider__content\"\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__image\"\u003E\r\n                        \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F17.jpg\"\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                      \u003Cdiv class=\"rkt-samsung-a36-slider__text\"\u003E\r\n                        \u003Ch2\u003EПриберіть зайве\u003C\u002Fh2\u003E\r\n                        \u003Cp\u003E\r\n                          Відкоригуйте фото з Galaxy A36 5G. Функція Edit Suggestion порадить, як можна покращити ваше фото, а Enhanced Object Eraser, а опція\r\n                          Enhanced Object Eraser допоможе прибрати зайві елементи. Відчуйте себе професійним фоторедактором.\r\n                        \u003C\u002Fp\u003E\r\n                      \u003C\u002Fdiv\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-button-next\"\u003E\u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-button-prev\"\u003E\u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"swiper-pagination\"\u003E\u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-content\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-content__text\"\u003E\r\n                \u003Ch2\u003EВисокоякісні камери для найкращої зйомки\u003C\u002Fh2\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-content__image\"\u003E\r\n                \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F18.jpg\"\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-place\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-place__flex\"\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item rkt-samsung-a36-place__item--right\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__text\"\u003E\r\n                    \u003Ch2\u003EСелфі, як у зірок\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003E\r\n                      Фіксуйте найкращі моменти свого захопливого життя, завдяки фронтальній камері на 12 Мп ви можете завжди поділитися ними зі своїми друзями.\r\n                      Спеціальний датчик дозволить робити чудові фото навіть за слабкого освітлення.\r\n                    \u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-place__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-place__image\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F19.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-before-after\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-before-after__images\"\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-before-after__slider\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-before-after__before\"\u003E\r\n                    \u003Cimg alt=\"\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F20.jpg\" class=\"lazyload\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-before-after__after\"\u003E\r\n                    \u003Cimg alt=\"\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F21.jpg\" class=\"lazyload\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-before-after__change\"\u003E\r\n                    \u003Cdiv class=\"rkt-samsung-a36-before-after__line\"\u003E\r\n                      \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F26.png\"\u003E\r\n                    \u003C\u002Fdiv\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-content\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-content__text\"\u003E\r\n                \u003Ch2\u003EНадійний і довговічний\u003C\u002Fh2\u003E\r\n                \u003Cp\u003E\r\n                  Galaxy A36 5G виконаний зі скла Corning Gorilla Glass Victus+ та оснащений захистом від пилу та вологи IP67, тому ви можете спокійно брати\r\n                  його з собою на природу та проводити активний відпочинок фіксуючи найприємніші моменти.\r\n                \u003C\u002Fp\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-content__image\"\u003E\r\n                \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F22.jpg\"\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n            \u003Cdiv class=\"rkt-samsung-a36-selfie\"\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-selfie__title\"\u003E\r\n                \u003Ch2\u003ESamsung Galaxy Experience\u003C\u002Fh2\u003E\r\n              \u003C\u002Fdiv\u003E\r\n              \u003Cdiv class=\"rkt-samsung-a36-selfie__flex\"\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-selfie__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__img\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F23.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__text\"\u003E\r\n                    \u003Ch2\u003EОновлений One UI 7\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003EНа Galaxy A36 5G встановлено оновлений One UI 7 – це робить його простим і зрозумілим у користуванні.\u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-selfie__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__img\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F24.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__text\"\u003E\r\n                    \u003Ch2\u003EМиттєва передача файлів\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003E\r\n                      Обмінюватись файлами тепер стало ще простіше, завдяки функції швидкої передачі даних ви можете легко передавати їх на Samsung Galaxy, iOS\r\n                      чи ПК.\r\n                    \u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n                \u003Cdiv class=\"rkt-samsung-a36-selfie__item\"\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__img\"\u003E\r\n                    \u003Cimg alt=\"\" class=\"lazyload\" data-src=\"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fx\u002Fimg3\u002F3368825\u002F25.jpg\"\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                  \u003Cdiv class=\"rkt-samsung-a36-selfie__text\"\u003E\r\n                    \u003Ch2\u003EЛегкий перехід з iOS\u003C\u002Fh2\u003E\r\n                    \u003Cp\u003EДодаток Smart Switch допоможе вам з легкістю перенести всі файли з будь-якого пристрою.\u003C\u002Fp\u003E\r\n                  \u003C\u002Fdiv\u003E\r\n                \u003C\u002Fdiv\u003E\r\n              \u003C\u002Fdiv\u003E\r\n            \u003C\u002Fdiv\u003E\r\n          \u003C\u002Fdiv\u003E\r\n        \u003C\u002Fdiv\u003E\r\n\r\n\u003Cscript\u003E\r\n      document.addEventListener(\"DOMContentLoaded\", function () {\r\n        let swiper = new Swiper(\".mySwiper\", {\r\n          slidesPerView: 1.5,\r\n          spaceBetween: 50,\r\n          pagination: {\r\n            el: \".swiper-pagination\",\r\n            clickable: true,\r\n          },\r\n          navigation: {\r\n            nextEl: \".swiper-button-next\",\r\n            prevEl: \".swiper-button-prev\",\r\n            clickable: true,\r\n          },\r\n          breakpoints: {\r\n            320: {\r\n              slidesPerView: 1.5,\r\n              spaceBetween: 20,\r\n            },\r\n            480: {\r\n              spaceBetween: 50,\r\n            },\r\n          },\r\n        });\r\n\r\n        let swiper2 = new Swiper(\".mySwiper2\", {\r\n          slidesPerView: 1,\r\n          spaceBetween: 50,\r\n          pagination: {\r\n            el: \".swiper-pagination\",\r\n            clickable: true,\r\n          },\r\n          navigation: {\r\n            nextEl: \".swiper-button-next\",\r\n            prevEl: \".swiper-button-prev\",\r\n            clickable: true,\r\n          },\r\n          breakpoints: {\r\n            320: {\r\n              slidesPerView: 1,\r\n              spaceBetween: 20,\r\n            },\r\n            480: {\r\n              spaceBetween: 50,\r\n            },\r\n          },\r\n        });\r\n\r\n        let swiper3 = new Swiper(\".mySwiper3\", {\r\n          slidesPerView: 1.5,\r\n          spaceBetween: 50,\r\n          pagination: {\r\n            el: \".swiper-pagination\",\r\n            clickable: true,\r\n          },\r\n          navigation: {\r\n            nextEl: \".swiper-button-next\",\r\n            prevEl: \".swiper-button-prev\",\r\n            clickable: true,\r\n          },\r\n          breakpoints: {\r\n            320: {\r\n              slidesPerView: 1.5,\r\n              spaceBetween: 20,\r\n            },\r\n            480: {\r\n              spaceBetween: 50,\r\n            },\r\n          },\r\n        });\r\n\r\n        const slider = document.querySelector(\".rkt-samsung-a36-before-after__slider\");\r\n        const before = document.querySelector(\".rkt-samsung-a36-before-after__before\");\r\n        const change = document.querySelector(\".rkt-samsung-a36-before-after__change\");\r\n        let isActive = false;\r\n\r\n        \u002F\u002F Функция обновления ширины before\r\n        const updateBeforeWidth = (position) =\u003E {\r\n          const { left, width } = slider.getBoundingClientRect();\r\n          const newPos = Math.min(Math.max(position - left, 0), width);\r\n          const widthPercentage = (newPos \u002F width) * 100;\r\n          before.style.clipPath = `inset(0 ${100 - widthPercentage}% 0 0)`;\r\n          change.style.left = `${widthPercentage}%`;\r\n        };\r\n\r\n        \u002F\u002F Универсальная функция для обработки мыши и тач-событий\r\n        const getPosition = (e) =\u003E (e.touches ? e.touches[0].clientX : e.clientX);\r\n\r\n        \u002F\u002F События для мыши и тач\r\n        [\"mousedown\", \"touchstart\"].forEach((event) =\u003E change.addEventListener(event, () =\u003E (isActive = true)));\r\n        [\"mouseup\", \"touchend\"].forEach((event) =\u003E document.addEventListener(event, () =\u003E (isActive = false)));\r\n        [\"mousemove\", \"touchmove\"].forEach((event) =\u003E\r\n          document.addEventListener(event, (e) =\u003E {\r\n            if (isActive) updateBeforeWidth(getPosition(e));\r\n          })\r\n        );\r\n\r\n        \u002F\u002F Устанавливаем стартовую ширину 50%\r\n        updateBeforeWidth(slider.getBoundingClientRect().width \u002F 2);\r\n      });\r\n    \u003C\u002Fscript\u003E"},"bloomreachRecommendationsByProduct":[],"bloomreachRecommendationsInfoByProduct":{},"bloomreachRecommendations":[],"bloomreachRecommendationsInfo":{},"loading":{"product":false,"dimensions":false,"description":false,"bloomreachRecommendations":false,"bloomreachRecommendationsByProduct":false,"colorPreview":false,"productBuySSI":false},"loaded":{"product":true,"dimensions":false,"description":true,"bloomreachRecommendations":false,"bloomreachRecommendationsByProduct":false,"colorPreview":false,"productBuySSI":false},"productBuySSI":"","appliedCouponName":""},"cities":{"baseCities":{"items":[{"id":"2704","name":"Бердичів","region":"Бердичівський р-г, Житомирська","flagBig":false,"flagStore":true,"externalCityId":5637183071,"uniqueFileHash":"691ae0b12b737"},{"id":"582","name":"Біла Церква","region":"Білоцерківський р-н, Київська","flagBig":true,"flagStore":true,"baseUrlSuffix":"bila-tserkva","prepositionalName":" в Білій Церкві","externalCityId":5637182119,"uniqueFileHash":"691ae09e85ef2"},{"id":"508","name":"Бориспіль","region":"Бориспільський р-н, Київська","flagBig":false,"flagStore":true,"externalCityId":5637183052,"uniqueFileHash":"691ae09c897f5"},{"id":"507","name":"Бровари","region":"Броварський р-н, Київська","flagBig":false,"flagStore":true,"externalCityId":5637183051,"uniqueFileHash":"691ae09c0021a"},{"id":"375","name":"Буча","region":"Бучанський р-н, Київська","flagBig":false,"flagStore":true,"externalCityId":5637182203,"uniqueFileHash":"691ae09a2ca3f"},{"id":"519","name":"Васильків","region":"Обухівський р-н, Київська","flagBig":fals
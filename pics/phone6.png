ages":false,"questions":false,"reviewCreate":false,"reviewAdded":false,"reviewsSummary":true,"reviewsImages":true},"messages":{"reviews":{"message":"","status":""}},"reviews":[{"reviewId":"12142953","parentId":"","createdAt":"2026-03-14 13:41:16","formattedCreatedAt":"14 березня 2026","nickname":"Наталя","productRating":100,"detail":"Покупкою задоволена, телефон в користуванні майже рік і недоліків не виявила","customerVotePositive":false,"votesQuantityPositive":0,"customerVoteNegative":false,"votesQuantityNegative":0,"wasOrdered":true,"images":[],"advantages":"Ціна - якість ","disadvantages":"Не виявила ","product":{"id":9999387,"sku":"3368827","name":"Смартфон Samsung Galaxy A36 5G 6\u002F128Gb Awesome Black (SM-A366BZKBEUC)","urlPath":"smartfon-samsung-galaxy-a36-5g-6-128gb-awesome-black-sm-a366bzkbeuc.html","imageUrl":"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fcatalog\u002Fproduct\u002Fcache\u002F5\u002Fsmall_image\u002F140x\u002F62defc7f46f3fbfc8afcd112227d1181\u002Fs\u002Fm\u002Fsm-a366_galaxy_a36_5g_awesome_black_front.jpg","groups":[{"color":"","value":"128 ГБ","label":"Пам'ять"},{"color":"#000000","value":"Чорний","label":"Інший колір"}]},"orderDate":"2025-05-31 00:00:00","usageTime":"понад 6 місяців у використанні"},{"reviewId":"12135411","parentId":"","createdAt":"2026-03-06 21:52:03","formattedCreatedAt":"6 березня 2026","nickname":"Василь","productRating":20,"detail":"Точно можу сказати що найгірший телефон який в мене був, не розумію звідки в нього позитивні відгуки, єдиний його плюс це екран. Батареї при середньому використанні  вистачає на день. Звук динаміків в порівнянні з А35 гірший, на другий день почалися проблеми при розмові, чути потріскування при розмові, чи то по мобільному зв'язку чи вайбер, відео відтворювались також з спотвореннями, прийшлось скинути всі налаштування а з ними стирається вся інформація з телефону - трошки помогло( косяки ПО). Підвисає навіть в самих простих іграх і в роботі, при включенні камери на вулиці зображення ривками секунд 5. Сканер відбитків просто відключив так як він не працював. Якщо довго телефон був без інтернету і включити його то телефон можна сміливо відкласти на пару хвилин,він зависає коли починають приходити сповіщення. Я розумію що телефон бюджетний но він точно не має виснути в елементарних базових задачах!!! Но в любому випадку я б не розглядав цю модель а може і саму фірму виробник.","customerVotePositive":false,"votesQuantityPositive":0,"customerVoteNegative":false,"votesQuantityNegative":0,"wasOrdered":false,"images":[],"comments":[{"reviewId":"12145469","parentId":"12135411","createdAt":"2026-03-16 18:01:06","formattedCreatedAt":"16 березня 2026","nickname":"Віктор","productRating":0,"detail":"Василь, Точно?","customerVotePositive":false,"votesQuantityPositive":0,"customerVoteNegative":false,"votesQuantityNegative":0,"wasOrdered":false,"images":[],"advantages":"","disadvantages":"","brandLogo":"review\u002Fbrands\u002Fsamsung.svg"}],"advantages":"Екран.","disadvantages":"Все інше.","product":{"id":9999307,"sku":"3368825","name":"Смартфон Samsung Galaxy A36 5G 8\u002F256Gb Awesome Black (SM-A366BZKGEUC)","urlPath":"smartfon-samsung-galaxy-a36-5g-8-256gb-awesome-black-sm-a366bzkgeuc.html","imageUrl":"https:\u002F\u002Fcdn.comfy.ua\u002Fmedia\u002Fcatalog\u002Fproduct\u002Fcache\u002F5\u002Fsmall_image\u002F140x\u002F62defc7f46f3fbfc8afcd112227d1181\u002Fs\u002Fm\u002Fsm-a366_galaxy_a36_5g_awesome_black_front.jpg","groups":[{"color":"","value":"256 ГБ","label":"Пам'ять"},{"color":"#000000","value":"Чорний","label":"Інший колір"}]}},{"reviewId":"12131226","parentId":"","createdAt":"2026-03-02 16:27:25","formattedCreatedAt":"2 березня 2026","nickname":"Вікторія","productRating":100,"detail":"Дуже класний телефон, не висне, камера хороша, класні фото виходять.Покупкою дуже задоволена.","customerVotePositive":false,"votesQuantityPositive":0,"customerVoteNegative":false,"votesQuantityNegative":0,"wasOrdered":true,"image":"media\u002Freview\u002Fmain\u002Ffile_
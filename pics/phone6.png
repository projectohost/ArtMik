2Fwww.samsung.com\u002Fph\u002Fsmartphones\u002Fgalaxy-a\u002Fgalaxy-a36-5g-awesome-lavender-256gb-sm-a366blvtphl\u002F","values":null,"code":"sait_proizv","description":"","optionsDescription":"","customerGroup":"6","displayValueNo":false},{"id":59491,"label":"Стан","value":"Новий","values":[{"id":0,"code":"novyj","description":"Новий"}],"code":"stan_smart","description":"","optionsDescription":"","filterable":true,"displayValueNo":false}]},{"id":2266,"label":"Екран","attributes":[{"id":4203,"label":"Діагональ дисплея","value":"6,7\"","values":[{"id":0,"code":"6com7","description":"6,7\""}],"code":"diag_displ_sm","description":"Відстань між двома протилежними кутами дисплея. Зазвичай позначається в дюймах.","optionsDescription":"Відстань між двома протилежними кутами дисплея. Зазвичай позначається в дюймах.","customerGroup":"1","filterBy":"smartf_diag","displayValueNo":false},{"id":3270,"label":"Роздільна здатність екрану","value":"2340x1080","values":[{"id":0,"code":"2340x1080","description":"2340x1080"}],"code":"smart_razr","description":"Величина, яка визначає кількість точок (елементів растрового зображення) на одиницю площі (або одиницю довжини). Більш висока роздільна здатність забезпечує більш точне відображення оригіналу зображення на дисплеї.","optionsDescription":"Величина, яка визначає кількість точок (елементів растрового зображення) на одиницю площі (або одиницю довжини). Більш висока роздільна здатність забезпечує більш точне відображення оригіналу зображення на дисплеї.","displayValueNo":false},{"id":4190,"label":"Тип екрану","value":"Super Amoled","values":[{"id":0,"code":"super-amoled","description":"Super Amoled"}],"code":"tip_ekr_sm","description":"Вказує на те, яку технологію використовували при створенні дисплею пристрою.","optionsDescription":"Вказує на те, яку технологію використовували при створенні дисплею пристрою.","filterable":true,"displayValueNo":false},{"id":39593,"label":"Частота оновлення екрану","value":"120 Гц","values":[{"id":0,"code":"120-gc","description":"120 Гц"}],"code":"smartfon_chastota_ekran","description":"Частота оновлення зображення дисплея показує, скільки разів в секунду на дисплей може виводитися нове зображення. Ця частота вимірюється в Герцах (Гц). Наприклад, якщо дисплей має частоту оновлення 144 Гц, це означає, що зображення на ньому оновлюється 144 рази в секунду. У поєднанні з високою частотою кадрів, що забезпечується спільно ЦП та ГП, висока частота оновлення забезпечує плавність зображення та більш високий показник FPS.","optionsDescription":"Частота оновлення зображення дисплея показує, скільки разів в секунду на дисплей може виводитися нове зображення. Ця частота вимірюється в Герцах (Гц). Наприклад, якщо дисплей має частоту оновлення 144 Гц, це означає, що зображення на ньому оновлюється 144 рази в секунду. У поєднанні з високою частотою кадрів, що забезпечується спільно ЦП та ГП, висока частота оновлення забезпечує плавність зображення та більш високий показник FPS.","filterable":true,"displayValueNo":false}]},{"id":2264,"label":"Зв'язок","attributes":[{"id":2836,"label":"Стандарти зв'язку","value":"3G, 4G, 5G","values":null,"code":"smart_st_sv","description":"","optionsDescription":"","displayValueNo":false},{"id":2109,"label":"Кількість SIM-карт","value":"1 SIM + e-SIM","values":[{"id":0,"code":"1-sim-plus-e-sim","description":"1 SIM + e-SIM"}],"code":"mobtel_new_poddergka_2_simnew","description":"Параметр, який вказує на те, яка кількість SIM-карт може бути встановлена в конкретному апараті.","optionsDescription":"Параметр, який вказує на те, яка кількість SIM-карт може бути встановлена в конкретному апараті.","filterable":true,"displayValueNo":false},{"id":39373,"label":"Розмір SIM-карти","value":"Nano-SIM","values":[{"id":0,"code":"nano-sim","description":"Nano-SIM"}],"code":"raz_simk_new","description":"Характеристика, яка вказує на розмір СІМ-карти який може підтримувати пристрій.","optionsDescription":"Характеристика, яка вказує на розмір СІМ-карти який може підтримувати пристрій.","filterable":true,"displayValueNo":false},{"id":39363,"label":"Підтримка e-SIM","value":"Є","values":[{"id":0,"code":"est","description":"Є"}],"code":"smartfon_e_sim","description":"Вбудована SIM (eSIM) - це найбільш сучасний стандарт SIM-карт, які вбудовується безпосередньо у сам пристрій.","optionsDescription":"Вбудована SIM (eSIM) - це найбільш сучасний стандарт SIM-карт, які вбудовується безпосередньо у сам пристрій.","filterable":true,"displayValueNo":false}]},{"id":2267,"label":"Процесор\u002FВідеоприскорювач","attributes":[{"id":39633,"label":"Модель процесора","value":"Qualcomm Snapdragon 6 Gen 3","values":[{"id":0,"code":"qualcomm-snapdragon-6-gen-3","description":"Qualcomm Snapdragon 6 Gen 3"}],"code":"smartfon_proc_new","description":"Функціональна частина пристрою, що призначена для інтерпретації команд. Виконує функцію обробки даних по заданій програмі шляхом виконання арифметичних та логічних операцій, а також функцію програмного керування роботою пристрою.","optionsDescription":"Функціональна частина пристрою, що призначена для інтерпретації команд. Виконує функцію обробки даних по заданій програмі шляхом виконання арифметичних та логічних операцій, а також функцію програмного керування роботою пристрою.","displayValueNo":false},{"id":2602,"label":"Кількість ядер","value":"8 ядер","values":[{"id":0,"code":"8-jader","description":"8 ядер"}],"code":"note_yader","description":"Процесори з великою кількістю ядер забезпечують найкращу продуктивність. Багатоядерні процесори можуть запускати кілька потоків обчислень одночасно, підвищуючи загальну продуктивність.","optionsDescription":"Процесори з великою кількістю ядер забезпечують найкращу продуктивність. Багатоядерні процесори можуть запускати кілька потоків обчислень одночасно, підвищуючи загальну продуктивність.","filterable":true,"displayValueNo":false},{"id":39623,"label":"Частота процессора","value":"4 x 2,4 ГГц + 4 x 1,8 ГГц","values":[{"id":0,"code":"4-x-2com4-ggc-plus-4-x-1com8-ggc","description":"4 x 2,4 ГГц + 4 x 1,8 ГГц"}],"code":"smartfon_chast_proc_new","description":"Тактова частота характеризує продуктивність підсистеми (процесора, пам'яті та ін.), тобто кількість виконаних операцій в секунду. Однак системи з однієї і тієї ж тактовою частотою можуть мати різну продуктивність, так як на виконання однієї операції різним системам може знадобитися різна кількість тактів (зазвичай від долей такту до десятків тактів). Крім того, системи, що використовують конвеєрну і паралельну обробку, можуть на одних і тих же тактах виконувати одночасно декілька операцій.","optionsDescription":"Тактова частота характеризує продуктивність підсистеми (процесора, пам'яті та ін.), тобто кількість виконаних операцій в секунду. Однак системи з однієї і тієї ж тактовою частотою можуть мати різну продуктивність, так як на виконання однієї операції різним системам може знадобитися різна кількість тактів (зазвичай від долей такту до десятків тактів). Крім того, системи, що використовують конвеєрну і паралельну обробку, можуть на одних і тих же тактах виконувати одночасно декілька операцій.","displayValueNo":false},{"id":39643,"label":"Модель графічного процесора","value":"Qualcomm Adreno 710","values":[{"id":0,"code":"qualcomm-adreno-710","description":"Qualcomm Adreno 710"}],"code":"smartfon_graf_proc_new","description":"Графічний процесор (англ. graphics processing unit, GPU) - окремий пристрій персонального комп'ютера, смартфона або ігрової приставки, що виконує графічний рендеринг. Сучасні графічні процесори дуже ефективно обробляють і зображують комп'ютерну графіку, завдяки спеціалізованій конвеєрній архітектурі вони набагато ефективніші в обробці графічної інформації, ніж типовий центральний процесор.","optionsDescription":"Графічний процесор (англ. graphics processing unit, GPU) - окремий пристрій персонального комп'ютера, смартфона або ігрової приставки, що виконує графічний рендеринг. Сучасні графічні процесори дуже ефективно обробляють і зображують комп'ютерну графіку, завдяки спеціалізованій конвеєрній архітектурі вони набагато ефективніші в обробці графічної інформації, ніж типовий центральний процесор.","customerGroup":"1","displayValueNo":false}]},{"id":2268,"label":"Пам'ять","attributes":[{"id":4195,"label":"Оперативна пам'ять","value":"8 ГБ","values":[{"id":0,"code":"8-gb","description":"8 ГБ"}],"code":"sm_ozu","description":"Оперативна пам'ять - енергозалежна частина пам'яті, в якій під час роботи пристрою зберігається машинний код (програми), який виконується в реальному часі, а також вхідні, вихідні та проміжні дані, що обробляються процесором. Чим більше обсяг пам'яті, тим кращою і більш злагодженою буде робота пристрою.","optionsDescription":"Оперативна пам'ять - енергозалежна частина пам'яті, в якій під час роботи пристрою зберігається машинний код (програми), який виконується в реальному часі, а також вхідні, вихідні та проміжні дані, що обробляються процесором. Чим більше обсяг пам'яті, тим кращою і більш злагодженою буде робота пристрою.","filterable":true,"displayValueNo":false},{"id":4205,"label":"Вбудована пам'ять","value":"256 ГБ","values":[{"id":0,"code":"256-gb","description":"256 ГБ"}],"code":"ob_vstr_pam","description":"Внутрішній об'єм пам'яті пристрою призначений для зберігання особистої інформації користувача, різних додатків і файлів. Заявлений обсяг пам'яті може не збігатися з фактичним, тому що частина заявленого об'єму зайнята системною інформацією (напр. операційною системою).","optionsDescription":"Внутрішній об'єм пам'яті пристрою призначений для зберігання особистої інформації користувача, різних додатків і файлів. Заявлений обсяг пам'яті може не збігатися з фактичним, тому що частина заявленого об'єму зайнята системною інформацією (напр. операційною системою).","filterBy":"smart_panyat","displayValueNo":false},{"id":2831,"label":"Розширення пам'яті","value":"Ні","values":[{"id":0,"code":"net","description":"Ні"}],"code":"smart_rash_pamati","description":"Можливість збільшення обсягу внутрішньої пам'яті пристрою за допомогою карти пам'яті. Це дозволяє зберігати ще більше інформації і файлів особистого характеру.","optionsDescription":"Можливість збільшення обсягу внутрішньої пам'яті пристрою за допомогою карти пам'яті. Це дозволяє зберігати ще більше інформації і файлів особистого характеру.","displayValueNo":true}]},{"id":2269,"label":"Камера","attributes":[{"id":4196,"label":"Основна камера","value":"50+8+5 Мп","values":[{"id":0,"code":"50plus8plus5-mp","description":"50+8+5 Мп"}],"code":"osnovn_kam","description":"Камера, яка розташована на тильній стороні пристрою. Залежно від роздільної здатності, дозволяє робити знімки гарної якості.","optionsDescription":"Камера, яка розташована на тильній стороні пристрою. Залежно від роздільної здатності, дозволяє робити знімки гарної якості.","customerGroup":"1","filterBy":"smart_kamf","displayValueNo":false},{"id":2793,"label":"Максимальна роздільна здатність відео","value":"3840 x 2160 4K UHD","values":[{"id":0,"code":"3840-x-2160-4k-uhd","description":"3840 x 2160 4K UHD"}],"code":"foto_razr_vid","description":"Чим вище роздільна здатність відео, яке записується за допомогою пристрою, тим більше і детальніше виходить відеозображення після його збереження.","optionsDescription":"Чим вище роздільна здатність відео, яке записується за допомогою пристрою, тим більше і детальніше виходить відеозображення після його збереження.","customerGroup":"1","displayValueNo":false},{"id":2117,"label":"Фронтальна камера","value":"12 Мп","values":[{"id":0,"code":"12-mp","description":"12 Мп"}],"code":"mobtel_new_frontkamera","description":"Фронтальна камера частіше використовується для здійснення відеодзвінків. Камери з більш високою роздільною здатністю забезпечують більш якісне зображення, однак і вимагають більш високої швидкості інтернету для якісного зв'язку.","optionsDescription":"Фронтальна камера частіше використовується для здійснення відеодзвінків. Камери з більш високою роздільною здатністю забезпечують більш якісне зображення, однак і вимагають більш високої швидкості інтернету для якісного зв'язку.","displayValueNo":true},{"id":4210,"label":"Спалах","value":"Так","values":[{"id":0,"code":"est","description":"Так"}],"code":"sm_vsp","description":"Джерело штучного освітлення, що призначене для створення короткочасних світлових спалахів великої інтенсивності. Спалах дозволяє робити знімки гарної якості в умовах слабкої освітленості.","optionsDescription":"Джерело штучного освітлення, що призначене для створення короткочасних світлових спалахів великої інтенсивності. Спалах дозволяє робити знімки гарної якості в умовах слабкої освітленості.","displayValueNo":false},{"id":39723,"label":"Зум","value":"10х цифровий","values":[{"id":0,"code":"10h-cifrovoj","description":"10х цифровий"}],"code":"smartfon_zoom","description":"Кратність зуму - це відношення максимальної фокусної відстані об'єктива (в мм) до мінімального фокусної відстані (в мм). Наприклад, якщо на об'єктиві вказано діапазон фокусних відстаней 4,5-45 мм, то кратність зуму дорівнюватиме 10. Зум може бути цифровим або оптичним: кратність оптичного зуму визначається оптико-механічними можливостями об'єктива, а кратність цифрового зуму - алгоритмами інтерполяції та обчислювальними можливостями процесора цифрового фотоапарата.","optionsDescription":"Кратність зуму - це відношення максимальної фокусної відстані об'єктива (в мм) до мінімального фокусної відстані (в мм). Наприклад, якщо на об'єктиві вказано діапазон фокусних відстаней 4,5-45 мм, то кратність зуму дорівнюватиме 10. Зум може бути цифровим або оптичним: кратність оптичного зуму визначається оптико-механічними можливостями об'єктива, а кратність цифрового зуму - алгоритмами інтерполяції та обчислювальними можливостями процесора цифрового фотоапарата.","displayValueNo":false}]},{"id":2270,"label":"Інтерфейси\u002Fроз'єми","attributes":[{"id":4197,"label":"Стандарти Wi-Fi","value":"802.11ax (Wi-Fi 6)","values":[{"id":0,"code":"80211ax-wi-fi-6","description":"802.11ax (Wi-Fi 6)"}],"code":"wifi_tip","description":"Вай-фай (від англ. Wireless Fidelity, Wi-Fi, WiFi; - бездротова правдивість відтворення) - торгова марка Wi-Fi Alliance та загальновживана назва для стандарту (IEEE 802.11) передачі цифрових потоків даних по радіоканалах. Обладнання, що відповідає стандарту IEEE 802.11, може бути протестовано Wi-Fi Alliance та отримати відповідний сертифікат і право нанесення логотипу Wi-Fi. Wi-Fi використовують для побудови мереж, де розгортання кабельної системи є неможливим або економічно недоцільним.","optionsDescription":"Вай-фай (від англ. Wireless Fidelity, Wi-Fi, WiFi; - бездротова правдивість відтворення) - торгова марка Wi-Fi Alliance та загальновживана назва для стандарту (IEEE 802.11) передачі цифрових потоків даних по радіоканалах. Обладнання, що відповідає стандарту IEEE 802.11, може бути протестовано Wi-Fi Alliance та отримати відповідний сертифікат і право нанесення логотипу Wi-Fi. Wi-Fi використовують для побудови мереж, де розгортання кабельної системи є неможливим або економічно недоцільним.","displayValueNo":false},{"id":4198,"label":"Bluetooth","value":"Версія 5.4","values":[{"id":0,"code":"versija-54","description":"Версія 5.4"}],"code":"bl_vers","description":"Bluetooth – це технологія бездротового зв’язку для приєднання різних електронних пристроїв (колонок, навушників, миші і т.п.) в межах певної відстані, а також для передачі даних. ","optionsDescription":"Bluetooth – це технологія бездротового зв’язку для приєднання різних електронних пристроїв (колонок, навушників, миші і т.п.) в межах певної відстані, а також для передачі даних. ","displayValueNo":false},{"id":17193,"label":"Навігаційна система","value":"GPS, Beidou, Galileo, QZSS, ГЛОНАСС","values":[{"id":0,"code":"gps","description":"GPS"},{"id":0,"code":"beidou","description":"Beidou"},{"id":0,"code":"galileo","description":"Galileo"},{"id":0,"code":"qzss","description":"QZSS"},{"id":0,"code":"glonass","description":"ГЛОНАСС"}],"code":"gps_smart_new","description":"Система, що дозволяє без проблем орієнтуватися на місцевості за допомогою завантажених карт або супутникового зв'язку. Також допомагає визначити власне місце розташування на карті.","optionsDescription":"Система, що дозволяє без проблем орієнтуватися на місцевості за допомогою завантажених карт або супутникового зв'язку. Також допомагає визначити власне місце розташування на карті.","displayValueNo":false},{"id":4201,"label":"Інтерфейс USB","value":"USB Type-C","values":[{"id":0,"code":"usb-type-c","description":"USB Type-C"}],"code":"int_usb","description":"Один з найбільш поширених роз'ємів. Він дозволяє синхронізувати пристрої, заряджати їх, передавати дані та інше.","optionsDescription":"Один з найбільш поширених роз'ємів. Він дозволяє синхронізувати пристрої, заряджати їх, передавати дані та інше.","displayValueNo":false},{"id":60132,"label":"Бездротові технології","value":"NFC","values":[{"id":0,"code":"nfc","description":"NFC"}],"code":"smartfon_bezdrot_teh","description":"","optionsDescription":"","filterable":true,"displayValueNo":false}]},{"id":2271,"label":"Акумулятор","attributes":[{"id":24483,"label":"Ємність акумулятора","value":"5000 мАг","values":[{"id":0,"code":"5000-mach","description":"5000 мАг"}],"code":"smartfon_akk_vipad","description":"Від ємності акумулятора безпосередньо залежить тривалість автономної експлуатації пристрою. Чим вище цей показник, тим довше телефон може працювати без підключення до мережі живлення.","optionsDescription":"Від ємності акумулятора безпосередньо залежить тривалість автономної експлуатації пристрою. Чим вище цей показник, тим довше телефон може працювати без підключення до мережі живлення.","customerGroup":"1","displayValueNo":false},{"id":16383,"label":"Швидка зарядка","value":"Є","values":[{"id":0,"code":"est","description":"Є"}],"code":"smartfon_fast_charde","description":"Технологія дбайливого і швидкого заряду акумуляторів, яка забезпечується можливістю передачі підвищеної потужності через кабельну інфраструктуру з роз'ємами USB, за допомогою комплекту мікросхем для обслуговування акумулятора і електроживлення мобільного пристрою.","optionsDescription":"Технологія дбайливого і швидкого заряду акумуляторів, яка забезпечується можливістю передачі підвищеної потужності через кабельну інфраструктуру з роз'ємами USB, за допомогою комплекту мікросхем для обслуговування акумулятора і електроживлення мобільного пристрою.","filterable":true,"displayValueNo":false},{"id":39603,"label":"Потужність зарядки","value":"45 Вт","values":[{"id":0,"code":"45-vt","description":"45 Вт"}],"code":"smartfon_moshnost_zar","description":"Потужність зарядки розраховується шляхом добутку сили струму і напруги. Чим більше значення потужності, тим швидше заряджається пристрій.","optionsDescription":"Потужність зарядки розраховується шляхом добутку сили струму і напруги. Чим більше значення потужності, тим швидше заряджається пристрій.","filterable":true,"displayValueNo":false}]},{"id":2272,"label":"Корпус","attributes":[{"id":16323,"label":"Захист корпусу","value":"Захист від пилу та вологи","values":[{"id":0,"code":"zaschita-ot-vlagi-i-pyli","description":"Захист від пилу та вологи"}],"code":"smartfon_protect","description":"Пристрій захищений від пилу та\u002Fабо вологи. Існує 7 ступенів захисту від пилу та 9 від рідин. Існують пристрої, які крім пилу та вологи, також захищені ще й від ударів та інших механічних пошкоджень.","optionsDescription":"Пристрій захищений від пилу та\u002Fабо вологи. Існує 7 ступенів захисту від пилу та 9 від рідин. Існують пристрої, які крім пилу та вологи, також захищені ще й від ударів та інших механічних пошкоджень.","filterable":true,"displayValueNo":false},{"id":4943,"label":"Клас захисту","value":"IP67","values":[{"id":0,"code":"ip67","description":"IP67"}],"code":"kl_zash","description":"International Protection Marking (в перекладі з англ. - «міжнародні коди захисту») - класифікація способу захисту, що забезпечується оболонкою технічного пристрою від доступу до небезпечних частин, попадання зовнішніх твердих предметів та (або) вологи. Перевіряється стандартними методами випробувань.\r\n\r\nМаркування ступеня захисту оболонки електрообладнання здійснюється за допомогою міжнародного знака захисту (IP) та двох цифр, з необов'язковим додаванням конкретизуючої літери, перша з яких означає захист від попадання твердих предметів, друга - від проникнення вологи.\r\n\r\nКод має вигляд IPXX, де на позиціях X знаходяться цифри або символ X, якщо ступінь не визначена. За цифрами можуть йти одна або дві букви, що дають допоміжну інформацію.\r\n\r\nМаксимальний ступінь захисту по цій класифікації - IP68: тобто захищений від пилу прилад, що витримує тривале занурення у воду під тиском. Наразі максимальний ступінь захисту - IP69-K: маркування корпусів виробів, що витримують високотемпературну мийку під високим тиском.","optionsDescription":"International Protection Marking (в перекладі з англ. - «міжнародні коди захисту») - класифікація способу захисту, що забезпечується оболонкою технічного пристрою від доступу до небезпечних частин, попадання зовнішніх твердих предметів та (або) вологи. Перевіряється стандартними методами випробувань.\r\n\r\nМаркування ступеня захисту оболонки електрообладнання здійснюється за допомогою міжнародного знака захисту (IP) та двох цифр, з необов'язковим додаванням конкретизуючої літери, перша з яких означає захист від попадання твердих предметів, друга - від проникнення вологи.\r\n\r\nКод має вигляд IPXX, де на позиціях X знаходяться цифри або символ X, якщо ступінь не визначена. За цифрами можуть йти одна або дві букви, що дають допоміжну інформацію.\r\n\r\nМаксимальний ступінь захисту по цій класифікації - IP68: тобто захищений від пилу прилад, що витримує тривале занурення у воду під тиском. Наразі максимальний ступінь захисту - IP69-K: маркування корпусів виробів, що витримують високотемпературну мийку під високим тиском.","filterable":true,"displayValueNo":false},{"id":16363,"label":"Біометричний захист","value":"Сканер відбитків пальців","values":[{"id":0,"code":"skaner-otpechatkov-palcev","description":"Сканер відбитків пальців"}],"code":"smartfon_bio_protect","description":"Процес перевірки особистості користувача що відбувається шляхом пред'явлення їм свого біометричного образу і шляхом перетворення цього образу відповідно до певного протоколу аутентифікації.","optionsDescription":"Процес перевірки особистості користувача що відбувається шляхом пред'явлення їм свого біометричного образу і шляхом перетворення цього образу відповідно до певного протоколу аутентифікації.","filterable":true,"displayValueNo":false},{"id":11053,"label":"Комплектація","value":"Смартфон, Кабель Type-C, Інструкція, Гарантійний талон","values":[{"id":0,"code":"smartfon","description":"Смартфон"},{"id":0,"code":"kabel-type-c","description":"Кабель Type-C"},{"id":0,"code":"instrukcija","description":"Інструкція"},{"id":0,"code":"garantijnyj-talon","description":"Гарантійний талон"}],"code":"komplekt_cennik","description":"","optionsDescription":"","displayValueNo":false},{"id":6933,"label":"Матеріал корпусу","value":"Пластик, Скло","values":[{"id":0,"code":"plastik","description":"Пластик"},{"id":0,"code":"steklo","description":"Скло"}],"code":"tip_korpusa_smartfon","description":"","optionsDescription":"","filterable":true,"displayValueNo":false},{"id":1347,"label":"Висота","value":"162,9 мм","values":null,"code":"visota_mm_universal","description":"","optionsDescription":"","displayValueNo":false},{"id":1191,"label":"Ширина","value":"78,2 мм","values":null,"code":"shirina_note","description":"","optionsDescription":"","displayValueNo":false},{"id":1396,"label":"Глибина","value":"7,4 мм","values":null,"code":"glubina_mm_universal","description":"","optionsDescription":"","displayValueNo":false},{"id":2143,"label":"Вага","value":"195 г","values":null,"code":"mobtel_new_ves","description":"","optionsDescription":"","displayValueNo":false},{"id":2269,"label":